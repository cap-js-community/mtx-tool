{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:monthly",
    ":automergeMinor",
    ":maintainLockFilesMonthly",
    "helpers:pinGitHubActionDigests"
  ],
  "ignorePresets": ["group:recommended", "group:monorepos"],
  "platformAutomerge": true,
  "groupName": "all",
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "description": "manage npm overrides manually",
      "matchDepTypes": ["overrides"],
      "enabled": false
    },
    {
      "description": "manage node upgrades manually",
      "matchDepNames": ["node"],
      "enabled": false
    },
    {
      "description": "manage ruby upgrades manually",
      "matchDepNames": ["ruby"],
      "enabled": false
    },
    {
      "description": "limit node-fetch for commonjs",
      "matchPackageNames": ["node-fetch"],
      "allowedVersions": "< 3.0.0"
    },
    {
      "description": "limit nock until it works",
      "matchPackageNames": ["nock"],
      "allowedVersions": "< 14.0.0"
    }
  ]
}
